<%- include ('../partials/header.html'); -%>
        <title>Student Home</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="../../css/student.css">
</head>
<body class="student-home-page">
      <%- include ('partials/navbar.html'); -%>

      <main class="student-page-wrap">
            <div class="container">
                  <section class="welcome-section">
                        <div class="row justify-content-center">
                              <div class="col-lg-10">
                                    <div class="welcome-banner text-center" id="ju">
                                          <h1>WELCOME <%= sname.toUpperCase() %></h1>
                                          <p>We are glad you're here.</p>
                                          <div class="welcome-actions">
                                                <a href="/student/viewdetailss" class="btn btn-light">View Profile</a>
                                                <a href="/student/oncampjob" class="btn btn-outline-light">On-Campus Jobs</a>
                                          </div>
                                    </div>
                              </div>
                        </div>
                  </section>

                  <section class="module-section">
                        <div class="row justify-content-center">
                              <div class="col-lg-8">
                                    <div class="module-shell">
                                          <div class="module-header text-center">
                                                <h2>Modules Available Under Your Access</h2>
                                                <hr class="f1">
                                                <p>Use the sections below to explore student, TPO, and company features from one place.</p>
                                          </div>

                                          <div class="module-card">
                                                <div id="effview">
                                                      <h3>+ Student Module</h3>
                                                      <div class="module-content">
                                                            <p>View Details</p>
                                                            <p>Update Details</p>
                                                            <p>Change Password</p>
                                                      </div>

                                                      <h3>+ TPO Module</h3>
                                                      <div class="module-content">
                                                            <p>View TPO Details</p>
                                                            <p>OnCampus Job Details</p>
                                                            <p>Applied Job Details</p>
                                                      </div>

                                                      <h3>+ Company(HR) Module</h3>
                                                      <div class="module-content">
                                                            <p>View Company Details</p>
                                                            <p>OffCampus Job Details</p>
                                                            <p>Applied Job Details</p>
                                                      </div>
                                                </div>
                                          </div>
                                    </div>
                              </div>
                        </div>
                  </section>
            </div>
      </main>

<%- include ('../partials/footer.html'); -%>
